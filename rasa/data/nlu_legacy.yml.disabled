# NLU training data for Taskify assistant (Vietnamese-first)
version: "3.1"

nlu:
  - intent: greet
    examples: |
      - xin chào
      - chào bạn
      - hello
      - hi
      - alo
      - chào buổi sáng
      - chào buổi tối
      - mình cần hỗ trợ
      - chào trợ lý
      - xin chào giúp mình
      - chào bạn nha
      - hello ngay
      - hi với
      - alo đi
      - chào buổi sáng cho tôi
      - chào buổi tối nhé
      - mình cần hỗ trợ liền
      - chào trợ lý giúp mình
      - xin chào nha
      - chào bạn ngay
      - hello với
      - hi đi
      - alo cho tôi
      - chào buổi sáng nhé
      - chào buổi tối liền

  - intent: goodbye
    examples: |
      - tạm biệt
      - chào tạm biệt
      - bye
      - goodbye
      - hẹn gặp lại
      - mình thoát nhé
      - kết thúc ở đây
